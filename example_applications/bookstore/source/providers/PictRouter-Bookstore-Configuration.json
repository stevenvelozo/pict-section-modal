{
	"ProviderIdentifier": "Pict-Router",

	"AutoInitialize": true,
	"AutoInitializeOrdinal": 0,

	"Routes":
	[
		{
			"path": "/Books",
			"template": "{~LV:Pict.PictApplication.showView(`Bookstore-BookList`)~}"
		},
		{
			"path": "/About",
			"template": "{~LV:Pict.PictApplication.showView(`Bookstore-About`)~}"
		}
	]
}
