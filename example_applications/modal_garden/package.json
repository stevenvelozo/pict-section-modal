{
	"name": "pict-section-modal-example-modal-garden",
	"version": "0.0.1",
	"description": "Modal Garden - Interactive showcase of all pict-section-modal features",
	"main": "source/Pict-Application-ModalGarden.js",
	"scripts": {
		"start": "node source/Pict-Application-ModalGarden.js",
		"build": "npx quack build && npx quack copy",
		"test": "echo \"no tests\" && exit 0"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.348",
		"pict-application": "^1.0.28",
		"pict-view": "^1.0.67",
		"pict-section-code": "file:../../../../pict-section-code",
		"pict-section-modal": "file:../../"
	},
	"devDependencies": {
		"quackage": "^1.0.59"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{ "from": "./html/*", "to": "./dist/" },
		{ "from": "./css/**", "to": "./dist/css/" },
		{ "from": "./node_modules/pict/dist/*", "to": "./dist/js/" }
	]
